PORT=8787

# Etsy Open API app credentials
ETSY_CLIENT_ID=replace_me
ETSY_CLIENT_SECRET=replace_me

# Must match your Etsy app redirect URL exactly
ETSY_REDIRECT_URI=http://localhost:8787/auth/callback

# scopes: listings_r,shops_r,transactions_r are baseline for SellerPulse sync
ETSY_SCOPES=listings_r shops_r transactions_r

# Optional token persistence overrides
# DATA_DIR=./data
# TOKEN_FILE=./data/etsy-token.json
