{
  "manifest_version": 3,
  "name": "SellerPulse for Etsy",
  "version": "0.2.0",
  "description": "Analyze Etsy listings in SellerPulse with one click.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "SellerPulse",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "*://*.etsy.com/*",
    "http://localhost:8787/*",
    "https://bradski7.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.etsy.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
